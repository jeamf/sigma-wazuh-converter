<group name="sigma,">
  <rule id="100001" level="15">
    <description>LSASS Memory Dump via Common Tools</description>
    <info type="text">Detects attempts to dump LSASS memory using common tools like procdump, mimikatz or taskmgr. Credential dumping from LSASS is a common post-exploitation technique.</info>
    <group>attack.credential-access,attack.T1003.001</group>
    <field name="win.eventdata.image" type="pcre2">\\procdump\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">\\procdump64\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">lsass</field>
    <field name="win.eventdata.commandLine" type="pcre2">sekurlsa</field>
    <field name="win.eventdata.commandLine" type="pcre2">lsadump</field>
  </rule>
</group>
