<group name="sigma,">
  <rule id="100001" level="12">
    <description>Suspicious Encoded PowerShell Command</description>
    <info type="text">Detects execution of PowerShell with encoded command arguments, a common technique used by attackers to obfuscate malicious scripts.</info>
    <group>attack.execution,attack.T1059.001,attack.defense-evasion,attack.T1027</group>
    <field name="win.eventdata.image" type="pcre2">\\powershell\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">\-EncodedCommand</field>
    <field name="win.eventdata.commandLine" type="pcre2">\-enc\ </field>
    <field name="win.eventdata.commandLine" type="pcre2">\-ec\ </field>
    <field name="win.eventdata.commandLine" type="pcre2">FromBase64String</field>
  </rule>
</group>
